<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Cormorant+Garamond:wght@500;600;700&family=Italianno&display=swap');

  :root {
    --bg: #18100A;
    --bg-card: transparent;
    --bg-section: rgba(80, 50, 20, 0.18);
    --primary: #7A5810;
    --primary-dark: #5A400A;
    --primary-light: #B8902F;
    --accent: #4A2810;
    --text: #1F1208;
    --text-dim: #4A3220;
    --green: #4A6730;
    --teal: #3A5848;
    --red: #8C3530;
    --orange: #985020;
    --gold: #A07820;
    --nouveau-green: #3D5A3D;
    --nouveau-blue: #2C4660;
    --nouveau-rose: #8B4555;
    --shadow: 0 4px 24px rgba(20, 10, 4, 0.6);
    --shadow-lg: 0 12px 48px rgba(20, 10, 4, 0.8);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Noto Sans JP', -apple-system, BlinkMacSystemFont, sans-serif;
    background:
      radial-gradient(ellipse at top, #2a1810 0%, #1F140A 50%, #0E0805 100%),
      #1F140A;
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }

  .container {
    max-width: 600px; margin: 0 auto; padding: 24px 16px;
    min-height: 100vh;
    display: flex; flex-direction: column; justify-content: center;
  }

  /* ===== CARD（羊皮紙風 + アールヌーボー装飾）===== */
  .card {
    background:
      linear-gradient(rgba(180, 140, 85, 0.12), rgba(150, 110, 65, 0.18)),
      url('羊皮紙テクスチャ.png') center/cover;
    background-color: #DEC396;
    border-radius: 14px;
    padding: 36px 28px;
    box-shadow:
      0 12px 48px rgba(15, 8, 3, 0.8),
      inset 0 0 60px rgba(80, 50, 20, 0.18);
    border: 2px solid rgba(80, 50, 20, 0.6);
    position: relative;
  }
  .card::before {
    content: '';
    position: absolute;
    inset: 6px;
    border: 1px solid rgba(100, 65, 20, 0.35);
    border-radius: 10px;
    pointer-events: none;
  }

  /* ===== アールヌーボー装飾 ===== */
  /* 四隅の花の装飾（カード共通）*/
  .card-corner {
    position: absolute;
    width: 42px;
    height: 42px;
    pointer-events: none;
    opacity: 0.55;
  }
  .card-corner.top-left    { top: 8px;    left: 8px; }
  .card-corner.top-right   { top: 8px;    right: 8px;  transform: scaleX(-1); }
  .card-corner.bottom-left { bottom: 8px; left: 8px;   transform: scaleY(-1); }
  .card-corner.bottom-right{ bottom: 8px; right: 8px;  transform: scale(-1, -1); }

  /* アールヌーボー区切りライン */
  .nouveau-divider {
    display: block;
    margin: 16px auto 20px;
    width: 100%;
    max-width: 360px;
    height: 28px;
    opacity: 0.7;
  }
  .nouveau-divider.compact {
    margin: 12px auto;
    height: 22px;
  }

  /* メダリオン（タイトル下のシンボル） */
  .nouveau-medallion {
    display: block;
    width: 64px;
    height: 64px;
    margin: 0 auto 16px;
    opacity: 0.85;
  }

  /* セクションフレーム（レーダー等を囲む装飾枠） */
  .nouveau-frame {
    position: relative;
    padding: 16px;
  }
  .nouveau-frame::before,
  .nouveau-frame::after {
    content: '';
    position: absolute;
    width: 32px;
    height: 32px;
    border: 2px solid var(--primary);
    opacity: 0.5;
    pointer-events: none;
  }
  .nouveau-frame::before {
    top: 0; left: 0;
    border-right: none;
    border-bottom: none;
    border-top-left-radius: 10px;
  }
  .nouveau-frame::after {
    bottom: 0; right: 0;
    border-left: none;
    border-top: none;
    border-bottom-right-radius: 10px;
  }

  /* 背景にアールヌーボー風の控えめなパターン */
  .card-pattern-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.04;
    background-image:
      radial-gradient(circle at 10% 20%, var(--nouveau-green) 1px, transparent 2px),
      radial-gradient(circle at 90% 80%, var(--nouveau-rose) 1px, transparent 2px),
      radial-gradient(circle at 30% 90%, var(--primary) 1px, transparent 2px),
      radial-gradient(circle at 70% 10%, var(--nouveau-blue) 1px, transparent 2px);
    background-size: 80px 80px;
    border-radius: inherit;
  }

  /* ===== SCREENS ===== */
  .screen { display: none; }
  .screen.active { display: block; animation: fadeUp 0.5s ease; }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ===== START SCREEN ===== */
  .start-screen { text-align: center; }

  .start-emblem {
    margin-bottom: 12px;
    text-align: center;
  }
  .start-emblem img {
    width: 220px;
    height: auto;
    max-width: 70%;
    /* 羊皮紙に馴染ませる（暗くしすぎない）*/
    filter:
      sepia(0.08) saturate(1.05)
      drop-shadow(0 8px 14px rgba(40, 20, 5, 0.45))
      drop-shadow(0 2px 4px rgba(40, 20, 5, 0.25));
  }

  .result-chara {
    margin-bottom: 8px;
    text-align: center;
  }
  .result-chara img {
    width: 220px;
    height: auto;
    max-width: 70%;
    filter:
      sepia(0.08) saturate(1.05)
      drop-shadow(0 8px 14px rgba(40, 20, 5, 0.45))
      drop-shadow(0 2px 4px rgba(40, 20, 5, 0.25));
  }

  h1.start-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 36px; font-weight: 700;
    color: #1F0E04;
    margin: 0 0 6px 0;
    letter-spacing: 2px;
    line-height: 1.3;
    text-shadow: 0 1px 1px rgba(255, 230, 180, 0.4);
  }
  .start-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px; font-weight: 700;
    color: #1F0E04;
    margin-bottom: 24px;
    letter-spacing: 2px;
    font-style: italic;
    text-shadow: 0 1px 0 rgba(255, 240, 210, 0.5);
  }

  .start-question {
    font-size: 22px; font-weight: 700;
    color: #0A0402;
    margin-bottom: 28px;
    line-height: 1.7;
    text-shadow: 0 1px 1px rgba(255, 240, 210, 0.6);
  }

  .start-divider {
    width: 80px; height: 1px;
    background: linear-gradient(90deg, transparent, var(--primary), transparent);
    margin: 0 auto 24px;
  }

  .start-desc {
    font-size: 16px; color: #100804;
    line-height: 2; margin-bottom: 12px;
    text-align: center;
    font-weight: 600;
    text-shadow: 0 1px 0 rgba(255, 240, 210, 0.5);
  }
  .start-desc .hl { color: #0A0402; font-weight: 700; }

  .start-residents {
    background: rgba(60, 35, 12, 0.18);
    border-left: 3px solid #5A400A;
    border-right: 3px solid #5A400A;
    padding: 14px 18px;
    margin: 16px auto 24px;
    border-radius: 8px;
    text-align: center;
    max-width: 320px;
  }
  .start-residents .label {
    font-size: 14px; color: #2A1A0A;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: 1px;
  }
  .start-residents ul {
    list-style: none;
    font-size: 16px;
    color: #100804;
    line-height: 2;
    font-weight: 600;
    text-shadow: 0 1px 0 rgba(255, 240, 210, 0.4);
  }
  .start-residents li::before {
    content: '・';
    color: #5A400A;
    margin-right: 4px;
  }

  .start-instruction {
    font-size: 16px;
    color: #100804;
    margin-bottom: 28px;
    text-align: center;
    line-height: 1.9;
    font-weight: 600;
    text-shadow: 0 1px 0 rgba(255, 240, 210, 0.4);
  }
  .start-instruction strong {
    color: #0A0402;
    font-weight: 700;
  }

  .start-incantation {
    font-family: 'Italianno', cursive;
    font-size: 30px;
    color: #4A2810;
    margin-bottom: 28px;
    font-style: italic;
    text-align: center;
    font-weight: 400;
    letter-spacing: 1px;
    line-height: 1.4;
  }

  .start-btn {
    display: inline-block;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 19px; font-weight: 700;
    color: #FFF5E0;
    background: linear-gradient(135deg, #7A1F1A 0%, #B02A20 50%, #7A1F1A 100%);
    border: 2px solid #E8D4A0;
    padding: 18px 56px;
    border-radius: 40px;
    cursor: pointer;
    box-shadow:
      0 8px 24px rgba(122, 31, 26, 0.5),
      0 0 0 1px rgba(40, 20, 8, 0.3),
      0 0 0 6px rgba(232, 212, 160, 0.15),
      inset 0 1px 0 rgba(255, 230, 200, 0.4);
    transition: all 0.2s;
    text-decoration: none;
    letter-spacing: 3px;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
    animation: ctaPulse 2.4s ease-in-out infinite;
    position: relative;
  }
  .start-btn:hover {
    transform: translateY(-3px) scale(1.03);
    background: linear-gradient(135deg, #8C2A24 0%, #C8332A 50%, #8C2A24 100%);
    animation: none;
    box-shadow:
      0 14px 32px rgba(176, 42, 32, 0.6),
      0 0 24px rgba(200, 50, 40, 0.4),
      inset 0 1px 0 rgba(255, 230, 200, 0.5);
  }
  .start-btn:active { transform: translateY(0); }

  .start-footer {
    font-size: 14px; color: #2A1A0A;
    margin-top: 20px;
    font-weight: 600;
  }

  .copyright {
    font-size: 13px; color: #2A1A0A;
    text-align: center;
    margin-top: 24px;
    font-weight: 500;
  }
  .copyright a {
    color: #2A1A0A;
    text-decoration: none;
    margin-left: 8px;
    font-weight: 600;
  }
  .copyright a:hover { text-decoration: underline; color: #1A0E04; }

  /* ===== PRIVACY MODAL ===== */
  .modal-overlay {
    display: none;
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.7);
    z-index: 1000;
    justify-content: center; align-items: center;
    padding: 20px;
  }
  .modal-overlay.active { display: flex; animation: fadeIn 0.2s ease; }
  @keyframes fadeIn { from {opacity:0;} to {opacity:1;} }
  .modal-content {
    background:
      linear-gradient(rgba(180, 140, 85, 0.12), rgba(150, 110, 65, 0.18)),
      url('羊皮紙テクスチャ.png') center/cover;
    background-color: #DEC396;
    border-radius: 14px;
    padding: 32px 28px;
    max-width: 600px;
    width: 100%;
    max-height: 80vh;
    overflow-y: auto;
    box-shadow: var(--shadow-lg);
    border: 2px solid rgba(80, 50, 20, 0.6);
  }
  .modal-content h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px; font-weight: 700;
    color: #1F0E04;
    margin-bottom: 20px;
    text-align: center;
    letter-spacing: 2px;
  }
  .modal-content h3 {
    font-size: 14px; font-weight: 700;
    color: #4A3010;
    margin-top: 20px; margin-bottom: 8px;
    padding-bottom: 4px;
    border-bottom: 1px solid rgba(80, 50, 20, 0.4);
  }
  .modal-content p {
    font-size: 13px; line-height: 1.9;
    color: #100804;
    margin-bottom: 8px;
    font-weight: 600;
  }
  .modal-close {
    display: block;
    margin: 20px auto 0;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 14px; font-weight: 500;
    color: #FAF0D8;
    background: linear-gradient(135deg, #6B4015 0%, #8B5A20 50%, #6B4015 100%);
    border: 1px solid var(--primary);
    padding: 10px 32px;
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .modal-close:hover { background: linear-gradient(135deg, #7B4F20 0%, #A06A28 50%, #7B4F20 100%); }

  /* ===== QUESTION SCREEN ===== */
  .q-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 12px;
  }
  .q-label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px; font-weight: 700;
    color: #2A1A0A; letter-spacing: 3px;
    text-shadow: 0 1px 0 rgba(255, 240, 210, 0.4);
  }
  .q-progress-text {
    font-size: 15px; color: #2A1A0A;
    font-weight: 600;
  }

  .progress-wrap {
    position: relative;
    margin-bottom: 24px;
    padding-top: 90px;
  }
  .progress-bar {
    width: 100%; height: 3px;
    background: rgba(110, 70, 30, 0.3);
    border-radius: 2px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--primary-dark), var(--primary), var(--primary-light));
    border-radius: 2px;
    transition: width 0.6s cubic-bezier(0.45, 0.05, 0.55, 0.95);
  }
  .walking-character {
    position: absolute;
    bottom: 6px;
    left: 0;
    width: 95px;
    height: auto;
    transition: left 0.7s cubic-bezier(0.45, 0.05, 0.55, 0.95);
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 2;
    filter: drop-shadow(0 4px 6px rgba(40, 20, 5, 0.4));
    user-select: none;
  }

  /* ===== WORLD MAP PUZZLE (BACKGROUND) ===== */
  .bg-puzzle {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 0;
    display: none;
    grid-template-columns: repeat(7, 1fr);
    grid-template-rows: repeat(2, 1fr);
    pointer-events: none;
    gap: 0;
  }
  .bg-puzzle.active { display: grid; }
  .piece {
    background-image: url('アールヌーボー調架空の世界地図.png');
    background-size: 700% 200%;
    opacity: 0;
    transform: scale(0.85) rotate(0deg);
    transition: opacity 1.2s ease, transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.7s ease;
    filter: brightness(0.7) saturate(0.95) blur(0.2px);
    /* ピース同士を少し重ねる */
    margin: -8px;
    /* ピースの形をランダム化 */
  }
  .piece.revealed {
    opacity: 0.85;
    transform: scale(1) rotate(var(--rot, 0deg));
  }
  .piece.revealed.just-revealed {
    animation: pieceClick 1.2s ease;
  }
  @keyframes pieceClick {
    0% { opacity: 1; filter: brightness(2.6) saturate(1.5); transform: scale(1.08) rotate(var(--rot, 0deg)); }
    50% { opacity: 1; filter: brightness(1.4) saturate(1.1) blur(0px); transform: scale(1) rotate(var(--rot, 0deg)); }
    100% { opacity: 0.85; filter: brightness(0.7) saturate(0.95) blur(0.2px); transform: scale(1) rotate(var(--rot, 0deg)); }
  }
  /* 完成時の全面表示（多角形カットを解除して綺麗な地図に） */
  .bg-puzzle.full-reveal .piece.revealed {
    opacity: 1;
    transform: scale(1) rotate(0deg);
    clip-path: none;
    margin: 0;
    /* 1.5秒待ってから光る（地図が組みあがってから） */
    animation: mapShine 2.2s ease-out 1.5s forwards;
    transition:
      clip-path 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      margin 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      filter 1.5s ease;
  }
  @keyframes mapShine {
    0%   { filter: brightness(1) saturate(1.1) blur(0); }
    20%  { filter: brightness(2.6) saturate(1.7) blur(0); }
    50%  { filter: brightness(1.8) saturate(1.4) blur(0); }
    100% { filter: brightness(1.1) saturate(1.15) blur(0); }
  }
  /* 結果画面でも綺麗な地図を維持 */
  .bg-puzzle.result-mode .piece.revealed {
    opacity: 0.55;
    transform: scale(1) rotate(0deg);
    filter: brightness(0.65) saturate(0.95);
    clip-path: none;
    margin: 0;
    animation: none;
  }
  /* 完成時の光のフラッシュ */
  .map-flash {
    position: fixed;
    top: 50%; left: 50%;
    width: 100vw; height: 100vw;
    transform: translate(-50%, -50%) scale(0);
    background: radial-gradient(circle, rgba(255, 240, 200, 0.95) 0%, rgba(232, 212, 160, 0.5) 30%, transparent 70%);
    z-index: 4;
    pointer-events: none;
    opacity: 0;
    border-radius: 50%;
    mix-blend-mode: screen;
  }
  .map-flash.active {
    animation: flashPulse 1.6s ease-out;
  }
  @keyframes flashPulse {
    0%   { opacity: 0; transform: translate(-50%, -50%) scale(0); }
    20%  { opacity: 1; transform: translate(-50%, -50%) scale(0.8); }
    50%  { opacity: 0.8; transform: translate(-50%, -50%) scale(1.4); }
    100% { opacity: 0; transform: translate(-50%, -50%) scale(2.2); }
  }
  /* 各ピースを不規則な多角形にカット + 微小な回転 */
  .piece[data-idx="0"]  { clip-path: polygon(8% 0%, 95% 12%, 100% 60%, 88% 100%, 5% 95%, 0% 40%); --rot: -1.2deg; }
  .piece[data-idx="1"]  { clip-path: polygon(0% 8%, 90% 0%, 100% 55%, 92% 100%, 12% 95%, 5% 50%); --rot: 0.8deg; }
  .piece[data-idx="2"]  { clip-path: polygon(5% 0%, 100% 5%, 95% 50%, 100% 95%, 8% 100%, 0% 45%); --rot: -0.5deg; }
  .piece[data-idx="3"]  { clip-path: polygon(0% 5%, 92% 0%, 100% 45%, 95% 100%, 0% 92%); --rot: 1.0deg; }
  .piece[data-idx="4"]  { clip-path: polygon(10% 5%, 100% 0%, 95% 60%, 100% 100%, 5% 95%, 0% 50%); --rot: -0.8deg; }
  .piece[data-idx="5"]  { clip-path: polygon(0% 0%, 95% 8%, 100% 50%, 88% 100%, 8% 100%, 5% 50%); --rot: 0.6deg; }
  .piece[data-idx="6"]  { clip-path: polygon(8% 0%, 100% 0%, 95% 45%, 100% 92%, 12% 100%, 0% 50%); --rot: -1.0deg; }
  .piece[data-idx="7"]  { clip-path: polygon(0% 5%, 88% 0%, 100% 50%, 90% 100%, 5% 95%, 8% 50%); --rot: 1.2deg; }
  .piece[data-idx="8"]  { clip-path: polygon(5% 0%, 95% 5%, 100% 55%, 92% 100%, 0% 95%, 8% 45%); --rot: -0.6deg; }
  .piece[data-idx="9"]  { clip-path: polygon(8% 5%, 100% 0%, 92% 45%, 100% 95%, 5% 100%, 0% 50%); --rot: 0.9deg; }
  .piece[data-idx="10"] { clip-path: polygon(0% 8%, 92% 0%, 100% 50%, 95% 100%, 12% 95%, 5% 45%); --rot: -1.1deg; }
  .piece[data-idx="11"] { clip-path: polygon(8% 0%, 100% 8%, 95% 55%, 100% 95%, 5% 100%, 0% 45%); --rot: 0.7deg; }
  .piece[data-idx="12"] { clip-path: polygon(0% 0%, 95% 5%, 100% 50%, 88% 100%, 5% 92%, 8% 45%); --rot: -0.9deg; }
  .piece[data-idx="13"] { clip-path: polygon(5% 5%, 100% 0%, 95% 50%, 100% 100%, 8% 95%, 0% 50%); --rot: 1.0deg; }
  /* 完成オーバーレイ */
  .world-complete-overlay {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 5;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    pointer-events: none;
    opacity: 0;
    animation: completeFade 4s ease forwards;
  }
  @keyframes completeFade {
    0% { opacity: 0; }
    25% { opacity: 1; }
    80% { opacity: 1; }
    100% { opacity: 0; }
  }
  .complete-card {
    text-align: center;
    background: rgba(8, 4, 1, 0.92);
    backdrop-filter: blur(16px);
    padding: 40px 52px;
    border-radius: 16px;
    border: 1.5px solid rgba(184, 144, 47, 0.6);
    box-shadow:
      0 0 80px rgba(184, 144, 47, 0.3),
      0 12px 48px rgba(0, 0, 0, 0.6);
    animation: completePop 1s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes completePop {
    0% { transform: scale(0.7); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }
  .complete-label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 14px;
    color: #E8D4A0;
    letter-spacing: 5px;
    margin-bottom: 18px;
    font-weight: 700;
  }
  .complete-title {
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 28px;
    color: #FAF0D8;
    letter-spacing: 2px;
    line-height: 1.5;
    font-weight: 700;
  }
  .complete-sub {
    font-size: 15px;
    color: #D4B57E;
    margin-top: 18px;
    letter-spacing: 1px;
    font-weight: 500;
  }
  /* 完成時にオーバーレイを薄く */
  .bg-overlay.complete-mode {
    background: radial-gradient(ellipse at center, rgba(31, 20, 10, 0.1) 0%, rgba(31, 20, 10, 0.4) 100%);
    transition: background 1.5s ease;
  }
  @media (max-width: 480px) {
    .complete-card { padding: 28px 32px; }
    .complete-title { font-size: 22px; }
  }
  /* 背景の暗いオーバーレイ */
  .bg-overlay {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 1;
    background: radial-gradient(ellipse at center, rgba(31, 20, 10, 0.45) 0%, rgba(14, 8, 5, 0.9) 100%);
    pointer-events: none;
    display: none;
  }
  .bg-overlay.active { display: block; }
  .container { position: relative; z-index: 2; }
  .piece[data-idx="0"]  { background-position: 0% 0%; }
  .piece[data-idx="1"]  { background-position: 16.67% 0%; }
  .piece[data-idx="2"]  { background-position: 33.33% 0%; }
  .piece[data-idx="3"]  { background-position: 50% 0%; }
  .piece[data-idx="4"]  { background-position: 66.67% 0%; }
  .piece[data-idx="5"]  { background-position: 83.33% 0%; }
  .piece[data-idx="6"]  { background-position: 100% 0%; }
  .piece[data-idx="7"]  { background-position: 0% 100%; }
  .piece[data-idx="8"]  { background-position: 16.67% 100%; }
  .piece[data-idx="9"]  { background-position: 33.33% 100%; }
  .piece[data-idx="10"] { background-position: 50% 100%; }
  .piece[data-idx="11"] { background-position: 66.67% 100%; }
  .piece[data-idx="12"] { background-position: 83.33% 100%; }
  .piece[data-idx="13"] { background-position: 100% 100%; }

  .q-text {
    font-size: 20px; font-weight: 700;
    line-height: 1.9;
    margin-bottom: 28px;
    color: #0A0402;
    min-height: 72px;
    text-shadow: 0 1px 1px rgba(255, 240, 210, 0.6);
  }
  .q-text .typing-cursor {
    display: inline-block;
    width: 2px; height: 22px;
    background: var(--primary);
    vertical-align: middle;
    margin-left: 2px;
    animation: blink 0.6s step-end infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .options {
    display: flex; flex-direction: column; gap: 10px;
  }
  .option-btn {
    display: block; width: 100%;
    background: rgba(248, 232, 195, 0.7);
    border: 1.5px solid rgba(80, 50, 20, 0.6);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 16px; color: #1A0E04;
    cursor: pointer; padding: 18px 22px;
    text-align: left;
    line-height: 1.7;
    transition: all 0.2s;
    border-radius: 8px;
    box-shadow: inset 0 1px 0 rgba(255, 245, 215, 0.6);
    font-weight: 600;
  }
  .option-btn:hover {
    border-color: #5A400A;
    background: rgba(220, 200, 155, 0.7);
    transform: translateX(4px);
    box-shadow:
      inset 0 1px 0 rgba(255, 240, 200, 0.5),
      0 4px 12px rgba(20, 10, 4, 0.25);
  }
  .option-btn.selected {
    border-color: #5A400A;
    background: rgba(160, 120, 32, 0.35);
    color: #0F0804;
    font-weight: 700;
  }
  .suit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    margin-right: 14px;
    vertical-align: middle;
    line-height: 1;
    font-size: 24px;
    text-shadow: 0 1px 0 rgba(255, 240, 210, 0.5);
    border: 1.5px solid currentColor;
    border-radius: 50%;
    background: rgba(255, 240, 200, 0.4);
    box-shadow:
      inset 0 1px 0 rgba(255, 240, 200, 0.5),
      0 2px 4px rgba(40, 20, 8, 0.2);
    position: relative;
  }
  .suit::before, .suit::after {
    content: '';
    position: absolute;
    width: 8px;
    height: 1px;
    background: currentColor;
    opacity: 0.6;
    top: 50%;
  }
  .suit::before { left: -12px; }
  .suit::after  { right: -12px; }
  .suit-d, .suit-h { color: #B02A20; }
  .suit-c, .suit-s { color: #1A0E04; }

  /* ===== RESULT SCREEN ===== */
  .result-screen { text-align: center; }

  /* 世界観イラスト */
  .world-image {
    position: relative;
    margin: -36px -28px 20px -28px;
    border-radius: 12px 12px 0 0;
    overflow: hidden;
    box-shadow: inset 0 -20px 40px rgba(80, 50, 20, 0.4);
  }
  .world-image img {
    width: 100%;
    height: auto;
    display: block;
  }
  .world-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, transparent 50%, rgba(140, 100, 60, 0.25) 80%, rgba(120, 85, 45, 0.45) 100%),
      linear-gradient(to top, transparent 70%, rgba(0, 0, 0, 0.3));
    pointer-events: none;
  }
  @media (max-width: 480px) {
    .world-image {
      margin: -28px -22px 16px -22px;
    }
  }

  .result-badge {
    display: inline-block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px; font-weight: 700;
    color: #FAF0D8;
    background: linear-gradient(135deg, #6B4015 0%, #8B5A20 50%, #6B4015 100%);
    border: 2px solid var(--primary);
    padding: 8px 32px;
    border-radius: 30px;
    letter-spacing: 5px;
    margin-bottom: 18px;
    box-shadow:
      0 4px 16px rgba(40, 20, 8, 0.4),
      inset 0 1px 0 rgba(255, 230, 180, 0.3);
  }

  h2.result-type-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 30px; font-weight: 700;
    color: #1F0E04;
    margin: 0 0 10px 0;
    letter-spacing: 1px;
    line-height: 1.4;
    text-shadow: 0 1px 1px rgba(255, 230, 180, 0.4);
  }
  .result-type-name .ja {
    font-family: 'Noto Sans JP', sans-serif;
  }
  .result-tagline {
    font-size: 17px; color: #2A1A0A;
    margin-bottom: 28px; line-height: 1.8;
    font-style: italic;
    font-weight: 700;
  }

  /* Scenery (情景説明) */
  .scenery-section {
    background: rgba(60, 35, 12, 0.18);
    border-left: 3px solid #5A400A;
    border-radius: 0 8px 8px 0;
    padding: 20px 22px;
    margin-bottom: 24px;
    text-align: left;
  }
  .scenery-section .label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 14px; font-weight: 700;
    color: #2A1A0A;
    letter-spacing: 3px;
    margin-bottom: 10px;
  }
  .scenery-section p {
    font-size: 16px;
    line-height: 2;
    color: #100804;
    font-weight: 600;
    text-shadow: 0 1px 0 rgba(255, 240, 210, 0.4);
  }

  /* Radar chart */
  .radar-section {
    margin-bottom: 24px;
    padding: 24px 20px 20px;
    background: rgba(139, 105, 20, 0.06);
    border-radius: 12px;
    border: 1px solid rgba(110, 70, 30, 0.25);
    position: relative;
  }
  .radar-section::before,
  .radar-section::after {
    content: '';
    position: absolute;
    width: 24px;
    height: 24px;
    border: 1.5px solid var(--primary);
    opacity: 0.6;
    pointer-events: none;
  }
  .radar-section::before {
    top: -1px; left: -1px;
    border-right: none;
    border-bottom: none;
    border-top-left-radius: 12px;
  }
  .radar-section::after {
    bottom: -1px; right: -1px;
    border-left: none;
    border-top: none;
    border-bottom-right-radius: 12px;
  }
  .radar-section .label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 14px; font-weight: 700;
    color: #2A1A0A;
    letter-spacing: 3px;
    text-align: center;
    margin-bottom: 12px;
  }
  .radar-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 16px;
  }
  .radar-aria {
    width: 210px;
    flex-shrink: 0;
  }
  .radar-aria img {
    width: 100%;
    height: auto;
    filter:
      sepia(0.08) saturate(1.05)
      drop-shadow(0 4px 8px rgba(40, 20, 5, 0.4));
  }
  .radar-wrap {
    flex: 1;
    max-width: 220px;
  }
  .radar-wrap canvas {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    display: block;
  }
  @media (max-width: 600px) {
    .radar-row {
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }
    .radar-aria { width: 200px; }
    .radar-wrap { max-width: 280px; width: 100%; }
  }
  @media (max-width: 380px) {
    .radar-aria { width: 170px; }
    .radar-wrap { max-width: 240px; }
  }
  .state-feedback {
    font-size: 15px;
    line-height: 1.9;
    color: #100804;
    text-align: left;
    padding: 14px 16px;
    background: rgba(140, 53, 48, 0.18);
    border-left: 3px solid #8C3530;
    border-radius: 0 8px 8px 0;
    font-weight: 600;
    text-shadow: 0 1px 0 rgba(255, 240, 210, 0.4);
  }
  .state-feedback .label {
    display: block;
    font-size: 14px;
    color: #4A0E08;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: 1px;
    text-shadow: 0 1px 0 rgba(255, 240, 210, 0.4);
  }

  /* Description cards */
  .desc-card {
    text-align: left;
    margin-bottom: 16px;
    padding: 20px 22px;
    background: rgba(60, 35, 12, 0.15);
    border-radius: 10px;
    border-left: 4px solid transparent;
    border-top: 1px solid rgba(80, 50, 20, 0.25);
    border-right: 1px solid rgba(80, 50, 20, 0.25);
    border-bottom: 1px solid rgba(80, 50, 20, 0.25);
  }
  .desc-card h3 {
    font-size: 17px; font-weight: 700;
    margin-bottom: 12px;
    letter-spacing: 0.5px;
  }
  .desc-card.strength-card {
    border-left-color: #4A6730;
    background: rgba(60, 90, 30, 0.18);
  }
  .desc-card h3.str-title {
    color: #2A4515;
  }
  .desc-card.challenge-card {
    border-left-color: #985020;
    background: rgba(140, 70, 20, 0.18);
  }
  .desc-card h3.chal-title {
    color: #5A2C08;
  }
  .desc-card p {
    font-size: 15px; line-height: 2;
    color: #100804;
    font-weight: 600;
    text-shadow: 0 1px 0 rgba(255, 240, 210, 0.4);
  }

  /* CTA */
  .cta-section {
    margin: 28px 0 16px;
    padding: 28px 24px;
    background: linear-gradient(135deg, rgba(139, 105, 20, 0.18) 0%, rgba(184, 144, 47, 0.12) 100%);
    border-radius: 12px;
    text-align: center;
    border: 1.5px solid rgba(139, 105, 20, 0.4);
  }
  .cta-section h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px; font-weight: 700;
    color: #1F0E04;
    margin-bottom: 14px; line-height: 1.6;
    letter-spacing: 2px;
    text-shadow: 0 1px 1px rgba(255, 230, 180, 0.4);
  }
  .cta-section p {
    font-size: 15px; color: #100804;
    line-height: 1.9; margin-bottom: 20px;
    font-weight: 600;
    text-shadow: 0 1px 0 rgba(255, 240, 210, 0.4);
  }
  .cta-btn {
    display: inline-block;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 18px; font-weight: 700;
    color: #FFF5E0;
    background: linear-gradient(135deg, #7A1F1A 0%, #B02A20 50%, #7A1F1A 100%);
    border: 2px solid #E8D4A0;
    padding: 16px 42px;
    border-radius: 40px;
    cursor: pointer;
    box-shadow:
      0 8px 24px rgba(122, 31, 26, 0.5),
      0 0 0 1px rgba(40, 20, 8, 0.3),
      inset 0 1px 0 rgba(255, 230, 200, 0.4);
    transition: all 0.2s;
    text-decoration: none;
    letter-spacing: 2px;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
    animation: ctaPulse 2.4s ease-in-out infinite;
  }
  @keyframes ctaPulse {
    0%, 100% { box-shadow: 0 8px 24px rgba(122, 31, 26, 0.5), 0 0 0 1px rgba(40, 20, 8, 0.3), inset 0 1px 0 rgba(255, 230, 200, 0.4); }
    50% { box-shadow: 0 8px 32px rgba(176, 42, 32, 0.7), 0 0 0 1px rgba(40, 20, 8, 0.3), 0 0 24px rgba(176, 42, 32, 0.4), inset 0 1px 0 rgba(255, 230, 200, 0.5); }
  }
  .cta-btn:hover {
    transform: translateY(-3px) scale(1.03);
    background: linear-gradient(135deg, #8C2A24 0%, #C8332A 50%, #8C2A24 100%);
    animation: none;
    box-shadow:
      0 14px 32px rgba(176, 42, 32, 0.6),
      0 0 24px rgba(200, 50, 40, 0.4),
      inset 0 1px 0 rgba(255, 230, 200, 0.5);
  }

  .official-link {
    display: block;
    margin-top: 14px;
    font-size: 14px;
    color: #2A1A0A;
    text-decoration: none;
    transition: color 0.15s;
    font-weight: 600;
  }
  .official-link:hover { color: #1A0E04; text-decoration: underline; }

  .retry-btn {
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 15px; color: #1F1208;
    background: rgba(80, 50, 20, 0.15);
    border: 1px solid rgba(80, 50, 20, 0.35);
    cursor: pointer; margin-top: 16px;
    transition: all 0.15s;
    padding: 8px 24px;
    border-radius: 20px;
    font-weight: 600;
  }
  .retry-btn:hover {
    color: #0A0402;
    background: rgba(80, 50, 20, 0.25);
  }

  /* ===== RESPONSIVE ===== */
  @media (pointer: coarse) {
    .option-btn { min-height: 48px; }
    .start-btn { min-height: 48px; }
    .cta-btn { min-height: 48px; }
  }

  @media (max-width: 480px) {
    .container { padding: 16px 12px; }
    .card { padding: 28px 22px; border-radius: 16px; }
    .start-title { font-size: 28px; }
    .start-question { font-size: 17px; }
    .q-text { font-size: 16px; }
    .option-btn { font-size: 14px; padding: 14px 16px; }
    .result-type-name { font-size: 26px; }
    .scenery-section p { font-size: 14px; }
  }

  @media (max-width: 380px) {
    .card { padding: 22px 18px; }
    .start-title { font-size: 24px; letter-spacing: 1px; }
    .q-text { font-size: 15px; }
    .option-btn { font-size: 13px; padding: 12px 14px; }
    .result-type-name { font-size: 22px; }
  }

  @supports (padding: env(safe-area-inset-bottom)) {
    .container {
      padding-bottom: calc(24px + env(safe-area-inset-bottom));
    }
  }
</style>
</head>
<body>

<noscript>
  <div style="padding: 40px 20px; max-width: 600px; margin: 40px auto; background: #DEC396; color: #1F1208; font-family: 'Noto Sans JP', sans-serif; line-height: 1.8; border-radius: 12px; border: 2px solid #5A400A;">
    <h1 style="font-family: 'Cormorant Garamond', serif; font-size: 28px; color: #1F0E04; margin-bottom: 16px; text-align: center;">幻想ビジネス世界観診断</h1>
    <p style="font-weight: 600;">この診断はJavaScriptを使用しています。お使いのブラウザのJavaScriptを有効にしてからお試しください。</p>
    <p style="margin-top: 16px;">この診断では、あなたの仕事や会社、商品やサービスを、ひとつの幻想世界として想像してもらい、12の世界観と4段階の完成度であなたのビジネス世界観を可視化します。</p>
    <p style="margin-top: 16px;"><a href="https://asobiari.com" style="color: #7A1F1A; font-weight: 700;">株式会社アソビアリ 公式サイト</a></p>
  </div>
</noscript>

<!-- ===== BG WORLD MAP PUZZLE ===== -->
<div class="bg-puzzle" id="bgPuzzle">
  <div class="piece" data-idx="0"></div>
  <div class="piece" data-idx="1"></div>
  <div class="piece" data-idx="2"></div>
  <div class="piece" data-idx="3"></div>
  <div class="piece" data-idx="4"></div>
  <div class="piece" data-idx="5"></div>
  <div class="piece" data-idx="6"></div>
  <div class="piece" data-idx="7"></div>
  <div class="piece" data-idx="8"></div>
  <div class="piece" data-idx="9"></div>
  <div class="piece" data-idx="10"></div>
  <div class="piece" data-idx="11"></div>
  <div class="piece" data-idx="12"></div>
  <div class="piece" data-idx="13"></div>
</div>
<div class="bg-overlay" id="bgOverlay"></div>
<div class="map-flash" id="mapFlash"></div>

<div class="container">

  <!-- ===== START SCREEN ===== -->
  <div class="screen active" id="startScreen">
    <div class="card">
      <!-- 四隅装飾 -->
      <svg class="card-corner top-left" viewBox="0 0 42 42">
        <path d="M 4 38 Q 4 18 18 12 Q 28 8 38 4" fill="none" stroke="#7A5810" stroke-width="1.2"/>
        <path d="M 4 30 Q 8 22 14 18" fill="none" stroke="#7A5810" stroke-width="0.8"/>
        <circle cx="4" cy="38" r="2.5" fill="#7A5810"/>
        <circle cx="38" cy="4" r="2.5" fill="#7A5810"/>
        <path d="M 18 12 Q 22 8 22 16 Q 18 14 18 12" fill="#7A5810" opacity="0.7"/>
      </svg>
      <svg class="card-corner top-right" viewBox="0 0 42 42">
        <path d="M 4 38 Q 4 18 18 12 Q 28 8 38 4" fill="none" stroke="#7A5810" stroke-width="1.2"/>
        <path d="M 4 30 Q 8 22 14 18" fill="none" stroke="#7A5810" stroke-width="0.8"/>
        <circle cx="4" cy="38" r="2.5" fill="#7A5810"/>
        <circle cx="38" cy="4" r="2.5" fill="#7A5810"/>
        <path d="M 18 12 Q 22 8 22 16 Q 18 14 18 12" fill="#7A5810" opacity="0.7"/>
      </svg>
      <svg class="card-corner bottom-left" viewBox="0 0 42 42">
        <path d="M 4 38 Q 4 18 18 12 Q 28 8 38 4" fill="none" stroke="#7A5810" stroke-width="1.2"/>
        <path d="M 4 30 Q 8 22 14 18" fill="none" stroke="#7A5810" stroke-width="0.8"/>
        <circle cx="4" cy="38" r="2.5" fill="#7A5810"/>
